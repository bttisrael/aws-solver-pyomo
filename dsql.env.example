# Copy this file to .env and fill the AWS values before running the DSQL upload.
# Keep the real .env private.

GOOGLE_APPLICATION_CREDENTIALS=C:\Users\israb\Documents\ML-production\service-account.json

AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_SESSION_TOKEN=only_if_using_temporary_credentials
AWS_DEFAULT_REGION=us-east-2

# Use either DSQL_CLUSTER_ENDPOINT or DSQL_CLUSTER_IDENTIFIER.
# The endpoint normally looks like: xxxxx.dsql.us-east-2.on.aws
DSQL_CLUSTER_ENDPOINT=your_cluster_endpoint
# DSQL_CLUSTER_IDENTIFIER=dsql-cluster-1

DSQL_DATABASE=postgres
DSQL_DB_USER=admin
